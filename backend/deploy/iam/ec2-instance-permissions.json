{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadStockMarketParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "arn:aws:ssm:<AWS_REGION>:<AWS_ACCOUNT_ID>:parameter/stock-market/prod/*"
    }
  ]
}
